# DeepSeek / OpenAI-compatible API
MODEL_API_KEY=your_deepseek_api_key_here
MODEL_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# Embedding model (local path)
EMBEDDING_MODEL_PATH=/path/to/bge-large-zh-v1.5

# Neo4j optional. Local RAG still works if Neo4j is unavailable.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# App
API_HOST=0.0.0.0
API_PORT=8000
WEB_API_URL=http://localhost:8000
TOP_K=5
