# ============================================================
# 车市镜 · 生产环境变量模板。复制为 .env.prod 后逐项填真值（.env.prod 已 gitignore，绝不提交）。
# 改密钥的铁律：JWT_SECRET / 各数据库口令 / MinIO 口令 全部换强随机串。
# 生成强随机串：  openssl rand -hex 32
# 连接串里的 host 用 compose 服务名（postgres/redis/minio），容器间内网互通。
# ============================================================

# ---- 域名（Caddy 自动 HTTPS 用，需解析到本机公网 IP）----
DOMAIN=chemirror.example.com
# CORS 收紧到正式域名（多个用逗号；务必带 https://，别再用 *）
CORS_ALLOW_ORIGINS=https://chemirror.example.com

# ---- LLM（DeepSeek，key 仅 v4-flash/v4-pro 可用）----
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro
LLM_API_KEY=sk-REPLACE_WITH_YOUR_DEEPSEEK_KEY
MAX_SQL_RETRY=2

# ---- JWT（务必换强随机串：openssl rand -hex 32）----
JWT_SECRET=REPLACE_WITH_64_HEX_RANDOM
JWT_EXPIRE_DAYS=7

# ---- 数据库连接串（应用读，host=postgres 服务名）----
# 分析库 bi（只读角色，Text2SQL 只查）
DATABASE_URL=postgresql+psycopg://bi_readonly:REPLACE_BI_RO_PW@postgres:5432/bi
# 应用库 app（读写角色，用户/会话/消息/知识库）
APP_DATABASE_URL=postgresql+psycopg://app_rw:REPLACE_APP_RW_PW@postgres:5432/app
# RAG 向量库（同 app 库，psycopg 原生串，非 +psycopg）
RAG_DATABASE_URL=postgresql://app_rw:REPLACE_APP_RW_PW@postgres:5432/app

# ---- PostgreSQL 容器初始化（initdb 建库建角色用；密码要与上面连接串一致）----
POSTGRES_SUPER_USER=postgres
POSTGRES_SUPER_PASSWORD=REPLACE_PG_SUPER_PW
POSTGRES_SUPER_DB=postgres
APP_DB_NAME=app
APP_DB_USER=app_rw
APP_DB_PASSWORD=REPLACE_APP_RW_PW
BI_DB_NAME=bi
BI_READONLY_USER=bi_readonly
BI_READONLY_PASSWORD=REPLACE_BI_RO_PW

# ---- 对象存储 MinIO（host=minio 服务名）----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=carmirror-admin
MINIO_SECRET_KEY=REPLACE_MINIO_PW_8PLUS
MINIO_SECURE=false
MINIO_BUCKET_UPLOADS=kb-uploads
MINIO_BUCKET_RAW=crawl-raw
# 容器 root 凭证（= 上面 access/secret）
MINIO_ROOT_USER=carmirror-admin
MINIO_ROOT_PASSWORD=REPLACE_MINIO_PW_8PLUS

# ---- Redis（Celery broker/backend，host=redis 服务名）----
REDIS_PASSWORD=REPLACE_REDIS_PW
REDIS_URL=redis://:REPLACE_REDIS_PW@redis:6379/0
CELERY_BROKER_URL=redis://:REPLACE_REDIS_PW@redis:6379/0
CELERY_RESULT_BACKEND=redis://:REPLACE_REDIS_PW@redis:6379/0

# ---- 本地 Embedding/Reranker 模型（容器内 /models 卷，DEPLOY.md 一次性下好）----
EMBED_MODEL_NAME=/models/bge-large-zh-v1.5
EMBED_MODEL_VERSION=bge-large-zh-v1.5
RERANK_MODEL_NAME=/models/bge-reranker-base
PARSER_BACKEND=lite          # 4C8G 扛不动 MinerU+BGE 同跑，用 PyMuPDF/pdfplumber

# ---- 定时任务加载 PG 分析库（worker 容器内连 postgres 服务，bi 库写入需 super）----
ANALYSIS_PG_URL=postgresql://postgres:REPLACE_PG_SUPER_PW@postgres:5432/bi

# ---- 部署辅助 ----
MODELS_DIR=./models          # 宿主机模型目录（挂进容器 /models）；建议放在数据盘
# 国内服务器拉 pip 慢可改清华镜像：
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
