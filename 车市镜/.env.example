# 复制本文件为 .env 后即可用（.env 已 gitignore）。
# 重要：值行不要写行内注释——docker compose 读 --env-file 时会把「# 注释」当成值的一部分，
#       导致密码/桶名出错。所有说明都单独成行放在值的上方。

# ---- LLM（二选一）----
# 通义千问 Qwen（阿里云百炼 DashScope，OpenAI 兼容）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# DeepSeek（备选）
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx

# ---- 数据库（分析库=只读；应用库=读写，两库分开）----
# 【demo / 纯本地零配置】用 SQLite（默认，下面两行就是）。
# 【联调 / 生产同款】拉起 deploy/docker-compose.dev.yml 后，把下面两行换成 PostgreSQL 连接串
# （代码零改动，app/config.py 只读这两个变量）。密码要与下方 infra 段一致：
#     DATABASE_URL=postgresql+psycopg://bi_readonly:bi_ro_pass_change_me@localhost:5432/bi
#     APP_DATABASE_URL=postgresql+psycopg://app_rw:app_rw_pass_change_me@localhost:5432/app
# 分析库 bi 用【只读】角色 bi_readonly（Text2SQL 只查不写）；应用库 app 用【读写】角色 app_rw。
# 驱动 psycopg(=psycopg v3) 已在 requirements.txt。
DATABASE_URL=sqlite:///bi_demo.db
APP_DATABASE_URL=sqlite:///app.db

# Text2SQL 失败自动重试次数
MAX_SQL_RETRY=2

# ---- 对象存储 MinIO（存上传/爬取的原始文档；S3 兼容）----
# access key / secret = 下方 MINIO_ROOT_USER / MINIO_ROOT_PASSWORD（dev 直接用 root；
# 生产建议在控制台另建一把受限 access key 只给应用用）。
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=carmirror-admin
MINIO_SECRET_KEY=minio_pass_change_me_8+
MINIO_SECURE=false
# 用户上传的知识库文档桶
MINIO_BUCKET_UPLOADS=kb-uploads
# 爬取的原始数据桶
MINIO_BUCKET_RAW=crawl-raw

# ---- Redis（Celery 队列 + 缓存）----
REDIS_URL=redis://:redis_pass_change_me@localhost:6379/0

# ---- RAG 离线入库管线（PRD-2 §5）----
# 向量库必须用 PostgreSQL+pgvector（SQLite 存不了 vector）。psycopg 原生串(非 +psycopg)。
# 注意：若本机已装原生 PostgreSQL 占用 5432，容器 PG 会被顶掉 → 把 POSTGRES_PORT 改 5433 并相应改端口。
RAG_DATABASE_URL=postgresql://app_rw:app_rw_pass_change_me@localhost:5432/app
# 本地 BGE 模型目录（从 ModelScope/HF 下到 models/，运行期不连 HF）；缺省用 BAAI/bge-large-zh-v1.5
# EMBED_MODEL_NAME=models/bge-large-zh-v1.5
EMBED_MODEL_VERSION=bge-large-zh-v1.5          # 换模型必须改版本并全量重建向量+HNSW（§5.8）
# PARSER_BACKEND=lite                          # lite=PyMuPDF/pdfplumber；mineru=待接入

# ---- JWT 鉴权（密钥务必改成长随机串，绝不提交到 git）----
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_DAYS=7

# ============================================================
# 基础设施容器配置（deploy/docker-compose.dev.yml 用 --env-file ../.env 读这一段）
# 这些是「拉起容器」的参数；上面的连接串是「应用连容器」的参数，密码两边要对上。
# 改任意密码后：①同步改上面对应连接串；②docker compose down -v 重置库再 up。
# 生产务必把所有 *_change_me 换成强随机密码。
# ============================================================

# -- PostgreSQL 容器 --
# 超级用户：仅建库建角色，后端不用它连
POSTGRES_SUPER_USER=postgres
POSTGRES_SUPER_PASSWORD=postgres_super_change_me
POSTGRES_SUPER_DB=postgres
POSTGRES_PORT=5432
# 分析库（只读脑）；BI_READONLY_PASSWORD 要与上面 DATABASE_URL 里的密码一致
BI_DB_NAME=bi
BI_READONLY_USER=bi_readonly
BI_READONLY_PASSWORD=bi_ro_pass_change_me
# 应用库（读写）；APP_DB_PASSWORD 要与上面 APP_DATABASE_URL 里的密码一致
APP_DB_NAME=app
APP_DB_USER=app_rw
APP_DB_PASSWORD=app_rw_pass_change_me

# -- MinIO 容器 --
# MINIO_ROOT_USER/PASSWORD 即上面的 MINIO_ACCESS_KEY/SECRET_KEY；密码须 >=8 位
MINIO_ROOT_USER=carmirror-admin
MINIO_ROOT_PASSWORD=minio_pass_change_me_8+
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -- Redis 容器 --
# REDIS_PASSWORD 要与上面 REDIS_URL 里的密码一致
REDIS_PASSWORD=redis_pass_change_me
REDIS_PORT=6379
