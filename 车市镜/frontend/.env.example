# 车市镜前端环境配置（复制为 .env 后按需修改）

# 后端 API 基址。本地开发指向 FastAPI（app/main.py，默认 8000）。
# 上线时改为线上域名，例如 https://api.cheshijing.com
VITE_API_BASE=http://localhost:8000

# 数据来源开关：
#   mock = 用内置本地 mock（后端未就绪时，按 PRD-2 §9.1 模拟 SSE 流，先把界面调通）
#   live = 连真后端（VITE_API_BASE）
# 后端就绪后改成 live 即可，无需改任何组件代码。
VITE_DATA_SOURCE=mock
