// Text2SQL 评测集（60 条）。problem→gold_sql，按执行结果集等价比对（等价 SQL 算对）。
// 实体均锚定 bi_demo.db 真实车系/品牌。口径：销量=fact_sales_rank.volume，能源类型 new_energy_type 1纯电/2插混/3增程。
{"id":"sql-001","q":"2025年纯电销量前十的车系","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v DESC LIMIT 10","note":"Top-N+能源+年过滤"}
{"id":"sql-002","q":"小米SU7一共卖了多少辆","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%小米SU7%'","note":"单车累计"}
{"id":"sql-003","q":"理想L6和理想L7谁卖得多","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%理想L6%' OR s.series_name LIKE '%理想L7%' GROUP BY s.series_id,s.series_name ORDER BY v DESC","note":"对比"}
{"id":"sql-004","q":"2025年增程车型销量最高的5款","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=3 AND d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v DESC LIMIT 5","note":"增程Top5"}
{"id":"sql-005","q":"Model Y累计销量是多少","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%Model Y%'","note":"单车累计"}
{"id":"sql-006","q":"2025年插混销量排名前十的车系","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=2 AND d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v DESC LIMIT 10","note":"插混Top10"}
{"id":"sql-007","q":"比亚迪2025年各车系累计销量","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id JOIN dim_date d ON d.date_id=f.date_id WHERE b.brand_name LIKE '%比亚迪%' AND d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v DESC","note":"品牌JOIN"}
{"id":"sql-008","q":"哪个品牌2025年新能源累计销量最高","gold_sql":"SELECT b.brand_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id JOIN dim_date d ON d.date_id=f.date_id WHERE d.year=2025 GROUP BY b.brand_id,b.brand_name ORDER BY v DESC LIMIT 1","note":"品牌聚合Top1"}
{"id":"sql-009","q":"2025年5月销量第一的车系","gold_sql":"SELECT s.series_name, f.volume FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE f.date_id=202505 ORDER BY f.volume DESC LIMIT 1","note":"某月Top1"}
{"id":"sql-010","q":"2025年纯电总销量是多少","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2025","note":"能源年总量"}
{"id":"sql-011","q":"星愿2025年每个月的销量","gold_sql":"SELECT d.ym, f.volume FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE s.series_name LIKE '%星愿%' AND d.year=2025 ORDER BY d.ym","note":"趋势按月"}
{"id":"sql-012","q":"五菱宏光MINIEV累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%五菱宏光MINIEV%'","note":"单车累计"}
{"id":"sql-013","q":"2025年销量超过30万辆的纯电车系有哪些","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2025 GROUP BY s.series_id,s.series_name HAVING SUM(f.volume)>300000 ORDER BY v DESC","note":"HAVING阈值"}
{"id":"sql-014","q":"理想汽车全系2025年累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id JOIN dim_date d ON d.date_id=f.date_id WHERE b.brand_name LIKE '%理想%' AND d.year=2025","note":"品牌总量"}
{"id":"sql-015","q":"2026年1月纯电销量前五","gold_sql":"SELECT s.series_name, f.volume FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE f.date_id=202601 AND f.new_energy_type=1 ORDER BY f.volume DESC LIMIT 5","note":"某月能源Top5"}
{"id":"sql-016","q":"蔚来各车系累计销量","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id WHERE b.brand_name LIKE '%蔚来%' GROUP BY s.series_id,s.series_name ORDER BY v DESC","note":"品牌车系明细"}
{"id":"sql-017","q":"2025年12月所有车系总销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f WHERE f.date_id=202512","note":"某月总量"}
{"id":"sql-018","q":"秦PLUS DM累计销量多少","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%秦PLUS DM%'","note":"单车累计"}
{"id":"sql-019","q":"2025年增程总销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=3 AND d.year=2025","note":"增程年总量"}
{"id":"sql-020","q":"小鹏MONA M03累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%小鹏MONA M03%'","note":"单车累计"}
{"id":"sql-021","q":"2025年各动力类型的总销量","gold_sql":"SELECT f.new_energy_type, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE d.year=2025 GROUP BY f.new_energy_type ORDER BY f.new_energy_type","note":"分组聚合"}
{"id":"sql-022","q":"指导价低于15万的纯电车系有多少个","gold_sql":"SELECT COUNT(*) v FROM dim_series WHERE powertrain='纯电' AND guide_price_max<15","note":"维度计数"}
{"id":"sql-023","q":"2025年销量前三的车系分别卖了多少","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v DESC LIMIT 3","note":"总Top3"}
{"id":"sql-024","q":"海鸥2025年累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE s.series_name LIKE '%海鸥%' AND d.year=2025","note":"单车年累计"}
{"id":"sql-025","q":"比亚迪和吉利银河谁2025年新能源销量更高","gold_sql":"SELECT b.brand_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id JOIN dim_date d ON d.date_id=f.date_id WHERE (b.brand_name LIKE '%比亚迪%' OR b.brand_name LIKE '%吉利银河%') AND d.year=2025 GROUP BY b.brand_id,b.brand_name ORDER BY v DESC","note":"品牌对比"}
{"id":"sql-026","q":"2025年第一季度纯电销量前十","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2025 AND d.quarter=1 GROUP BY s.series_id,s.series_name ORDER BY v DESC LIMIT 10","note":"季度过滤"}
{"id":"sql-027","q":"元PLUS累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%元PLUS%'","note":"单车累计"}
{"id":"sql-028","q":"2025年插混总销量是多少","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=2 AND d.year=2025","note":"插混年总量"}
{"id":"sql-029","q":"上市榜单中销量过20万的车系有几个（2025）","gold_sql":"SELECT COUNT(*) v FROM (SELECT s.series_id FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE d.year=2025 GROUP BY s.series_id HAVING SUM(f.volume)>200000)","note":"子查询计数"}
{"id":"sql-030","q":"小米SU7和Model Y谁卖得多","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%小米SU7%' OR s.series_name LIKE '%Model Y%' GROUP BY s.series_id,s.series_name ORDER BY v DESC","note":"对比"}
{"id":"sql-031","q":"理想汽车有哪几个车系","gold_sql":"SELECT s.series_name FROM dim_series s JOIN dim_brand b ON b.brand_id=s.brand_id WHERE b.brand_name LIKE '%理想%'","note":"维度列举"}
{"id":"sql-032","q":"2025年纯电销量最低的5款车系","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v ASC LIMIT 5","note":"升序Top"}
{"id":"sql-033","q":"汉DM累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%汉DM%'","note":"单车累计"}
{"id":"sql-034","q":"2024年和2025年纯电总销量对比","gold_sql":"SELECT d.year, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year IN (2024,2025) GROUP BY d.year ORDER BY d.year","note":"跨年对比"}
{"id":"sql-035","q":"销量榜上有多少个不同车系（2025）","gold_sql":"SELECT COUNT(DISTINCT f.series_id) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE d.year=2025","note":"去重计数"}
{"id":"sql-036","q":"AION Y累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%AION Y%'","note":"单车累计"}
{"id":"sql-037","q":"2025年6月纯电销量前十","gold_sql":"SELECT s.series_name, f.volume FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE f.date_id=202506 AND f.new_energy_type=1 ORDER BY f.volume DESC LIMIT 10","note":"某月能源Top10"}
{"id":"sql-038","q":"宋Pro DM累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%宋Pro DM%'","note":"单车累计"}
{"id":"sql-039","q":"2025年增程车系有哪些上过榜","gold_sql":"SELECT DISTINCT s.series_name FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=3 AND d.year=2025","note":"去重列举"}
{"id":"sql-040","q":"五菱汽车2025年累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id JOIN dim_date d ON d.date_id=f.date_id WHERE b.brand_name LIKE '%五菱%' AND d.year=2025","note":"品牌总量"}
{"id":"sql-041","q":"2025年12月销量前五的车系","gold_sql":"SELECT s.series_name, f.volume FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE f.date_id=202512 ORDER BY f.volume DESC LIMIT 5","note":"某月Top5"}
{"id":"sql-042","q":"指导价30万以上的车系有多少个","gold_sql":"SELECT COUNT(*) v FROM dim_series WHERE guide_price_min>=30","note":"维度计数"}
{"id":"sql-043","q":"海豚累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%海豚%'","note":"单车累计"}
{"id":"sql-044","q":"2025年纯电车系平均累计销量","gold_sql":"SELECT AVG(t) v FROM (SELECT SUM(f.volume) t FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2025 GROUP BY s.series_id)","note":"子查询求均值"}
{"id":"sql-045","q":"极氪各车系累计销量","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id WHERE b.brand_name LIKE '%极氪%' GROUP BY s.series_id,s.series_name ORDER BY v DESC","note":"品牌明细"}
{"id":"sql-046","q":"2025年销量最高的插混车系是哪个","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=2 AND d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v DESC LIMIT 1","note":"插混Top1"}
{"id":"sql-047","q":"Model 3累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%Model 3%'","note":"单车累计"}
{"id":"sql-048","q":"2025年每月纯电总销量趋势","gold_sql":"SELECT d.ym, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2025 GROUP BY d.ym ORDER BY d.ym","note":"按月趋势"}
{"id":"sql-049","q":"小米YU7累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%小米YU7%'","note":"单车累计"}
{"id":"sql-050","q":"2025年纯电销量排名第11到20的车系","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v DESC LIMIT 10 OFFSET 10","note":"分页OFFSET"}
{"id":"sql-051","q":"银河E5累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%银河E5%'","note":"单车累计"}
{"id":"sql-052","q":"2025年纯电、插混、增程各有多少款车系上榜","gold_sql":"SELECT f.new_energy_type, COUNT(DISTINCT f.series_id) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE d.year=2025 GROUP BY f.new_energy_type ORDER BY f.new_energy_type","note":"分组去重计数"}
{"id":"sql-053","q":"腾势各车系累计销量","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id WHERE b.brand_name LIKE '%腾势%' GROUP BY s.series_id,s.series_name ORDER BY v DESC","note":"品牌明细"}
{"id":"sql-054","q":"2026年1到3月纯电总销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE f.new_energy_type=1 AND d.year=2026 AND d.month BETWEEN 1 AND 3","note":"区间月份"}
{"id":"sql-055","q":"理想L6 2025年每月销量","gold_sql":"SELECT d.ym, f.volume FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE s.series_name LIKE '%理想L6%' AND d.year=2025 ORDER BY d.ym","note":"单车按月"}
{"id":"sql-056","q":"2025年销量前十里有几款是增程","gold_sql":"SELECT COUNT(*) v FROM (SELECT s.series_id, MAX(s.powertrain) pt FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_date d ON d.date_id=f.date_id WHERE d.year=2025 GROUP BY s.series_id ORDER BY SUM(f.volume) DESC LIMIT 10) WHERE pt='增程'","note":"子查询+条件计数"}
{"id":"sql-057","q":"唐DM累计销量","gold_sql":"SELECT SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE s.series_name LIKE '%唐DM%'","note":"单车累计"}
{"id":"sql-058","q":"2025年比亚迪销量最高的车系","gold_sql":"SELECT s.series_name, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id JOIN dim_brand b ON b.brand_id=s.brand_id JOIN dim_date d ON d.date_id=f.date_id WHERE b.brand_name LIKE '%比亚迪%' AND d.year=2025 GROUP BY s.series_id,s.series_name ORDER BY v DESC LIMIT 1","note":"品牌内Top1"}
{"id":"sql-059","q":"2025年纯电销量总和与插混销量总和","gold_sql":"SELECT f.new_energy_type, SUM(f.volume) v FROM fact_sales_rank f JOIN dim_date d ON d.date_id=f.date_id WHERE d.year=2025 AND f.new_energy_type IN (1,2) GROUP BY f.new_energy_type ORDER BY f.new_energy_type","note":"多类对比"}
{"id":"sql-060","q":"2025年12月排名上升的车系有哪些（当月排名优于上期）","gold_sql":"SELECT s.series_name, f.rank, f.last_rank FROM fact_sales_rank f JOIN dim_series s ON s.series_id=f.series_id WHERE f.date_id=202512 AND f.last_rank IS NOT NULL AND f.rank < f.last_rank ORDER BY (f.last_rank - f.rank) DESC","note":"last_rank环比上升(难)"}
