    model.train()
    # ... 训练代码 ...
    
    # --- 每个 epoch 在测试集上评估 ---
    model.eval()
    with torch.no_grad():  # ← 新增：不计算梯度
        for x_val, y_val in test_loader:
            # ... 评估代码 ...
    
    # --- 只保存最好的模型 ---
    if current_acc > best_acc:
        best_acc = current_acc
        torch.save(model.state_dict(), 'model/phonemodel.pth')
```


