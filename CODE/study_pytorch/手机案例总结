    nn.Linear(input_dim, 128),
    nn.BatchNorm1d(128),      # ← 新增：批标准化
    nn.ReLU(),
    nn.Dropout(0.3),          # ← 新增：随机丢弃 30% 神经元
    
    nn.Linear(128, 64),       # ← 维度调整：256→64
